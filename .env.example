# ==========================================
# Core Application Configuration
# ==========================================

# Server Configuration
# The host to bind to
HOST=localhost
# The port the application will listen on
PORT=3000

# Database Configuration
# Supported types: 'mysql', 'pgsql', 'sqlite' (default)
DB_TYPE=sqlite
# For MySQL: mysql://user:password@host:port/database
# For PostgreSQL: postgresql://user:password@host:port/database
# For SQLite: file:./storage/database/knowdo.db
DATABASE_URL=file:./storage/database/knowdo.db

# Aliyun ESA AI CAPTCHA
# Enable CAPTCHA verification
NUXT_PUBLIC_ALIYUN_CAPTCHA_ENABLED=false
# CAPTCHA region, must match the ESA console configuration
NUXT_PUBLIC_ALIYUN_CAPTCHA_REGION=cn
# Identity prefix from the ESA AI CAPTCHA console, for example esa-xxxxxx. This value is exposed to the browser and is not a backend secret.
NUXT_PUBLIC_ALIYUN_CAPTCHA_PREFIX=
# Login Scene ID for the ESA CAPTCHA rule.
NUXT_PUBLIC_ALIYUN_CAPTCHA_LOGIN_SCENE_ID=
